const MAP_DATA = (() => {
  const out = [];
  let lastCompany = "";
  for (const r of RAW_DATA) {
    const c = (r.company || "").trim();
    if (c) lastCompany = c;
    out.push({ ...r, company_ff: c || lastCompany });
  }
  return out;
})();

const $ = (id)=>document.getElementById(id);

function showFatal(msg, sub){
  const box = $("fatal");
  box.style.display = "block";
  box.innerHTML = (msg || "문제가 발생했습니다.");
  if (sub) box.innerHTML += "<br/><small>" + String(sub) + "</small>";
}
function hideFatal(){ $("fatal").style.display = "none"; }

function norm(s){
  return (s||"").toString().toLowerCase().replace(/\s+/g," ").trim();
}
function normCompact(s){
  return norm(s).replace(/\s+/g,"").replace(/[()\-\.,]/g,"");
}
function fmt(v){
  if (v===null || v===undefined) return "";
  const s = String(v).trim();
  if (!s || s.toLowerCase()==="nan") return "";
  return s;
}
function haversineKm(lat1, lon1, lat2, lon2){
  const R = 6371;
  const dLat = (lat2-lat1)*Math.PI/180;
  const dLon = (lon2-lon1)*Math.PI/180;
  const a = Math.sin(dLat/2)**2 +
            Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*
            Math.sin(dLon/2)**2;
  return 2*R*Math.asin(Math.sqrt(a));
}

