      const lat = Number(r.lat), lon = Number(r.lon);
      if (!isFinite(lat) || !isFinite(lon)) continue;

      const company = fmt(r.company_ff);
      const factory = fmt(r.factory);
      const addr = fmt(r.address);
      const tel = fmt(r.tel);
      const cap = fmt(r.capacity);
      const mix = fmt(r.mixer);

      const isHL = company.replace(/\s+/g,"").includes(HIGHLIGHT);

      const popup = `
        <div style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Noto Sans KR',sans-serif;font-size:12px;line-height:1.35;">
          <div style="font-weight:800;font-size:13px;">${company}${factory?` · ${factory}`:""}</div>
          <div style="margin-top:4px;color:#444;">${addr}</div>
          <div style="margin-top:4px;color:#555;">생산: <b>${cap||"-"}</b> · 믹서: <b>${mix||"-"}</b></div>
          <div style="margin-top:4px;color:#666;">TEL: ${tel||"-"}</div>
        </div>`;

      const marker = L.marker([lat, lon], { icon: pinIcon(isHL), riseOnHover: true }).bindPopup(popup);

      cluster.addLayer(marker);
      markers.push({ row:r, marker });
      bounds.push([lat, lon]);
    }

    map.addLayer(cluster);

    if (bounds.length) {
      map.fitBounds(bounds, {padding:[40,40]});
      setTimeout(()=>map.invalidateSize(true), 50);
      hideFatal();
    } else {
      showFatal("표시할 좌표가 없습니다.", "lat/lon 값이 비어있는 행이 많을 수 있어.");
    }

    /** ===== 2025 신규/이전 공장 좌표 백그라운드 보정 =====
     *  2025 통계연보에 새로 등재됐거나 주소가 바뀐 공장(g:1)은 기존 좌표가 없어
     *  인근 임시좌표로 먼저 표시한 뒤, 최초 1회 Nominatim으로 엑셀 주소의 실좌표를 조회한다.
     *  결과는 localStorage 캐시. (엑셀 각 행을 독립 공장으로 처리 / 1요청/초 / 인터넷 필요) */
    (function geocodeApprox(){
      const pending = markers.filter(m => m.row && m.row.g);
      if (!pending.length) return;
      let cache = {};
      try { cache = JSON.parse(localStorage.getItem("remicon_geo_2025") || "{}"); } catch(e){}
      let i = 0;
      function apply(m, lat, lon){
        m.marker.setLatLng([lat, lon]);
        m.row.lat = lat; m.row.lon = lon;
      }
      function step(){
        if (i >= pending.length) return;
        const m = pending[i++];
        const addr = fmt(m.row.address);
        const c = cache[addr];
        if (c && isFinite(c.lat) && isFinite(c.lon)) { apply(m, c.lat, c.lon); return setTimeout(step, 0); }
        geocodeOSM(addr).then(res=>{
          if (res && isFinite(res.lat) && isFinite(res.lon)) {
            apply(m, res.lat, res.lon);
            cache[addr] = { lat: res.lat, lon: res.lon };
            try { localStorage.setItem("remicon_geo_2025", JSON.stringify(cache)); } catch(e){}
          }
        }).catch(()=>{}).finally(()=>{ setTimeout(step, 1100); });
      }
      setTimeout(step, 3000);
    })();

    /** ===== 좌측 검색 ===== */
    const q = $("q");
    const results = $("results");

    const searchIndex = markers.map((m, idx)=>{
      const r = m.row;
      const company = fmt(r.company_ff);
      const factory = fmt(r.factory);
      const addr = fmt(r.address);
      return {
        idx,
        company,
        factory,
        addr,
        key: normCompact(company + " " + factory + " " + addr)
      };
    });

    function jumpTo(idx){
      const m = markers[idx];
      if (!m) return;
      const lat = Number(m.row.lat), lon = Number(m.row.lon);
      map.setView([lat, lon], 13, {animate:true});
      cluster.zoomToShowLayer(m.marker, ()=>m.marker.openPopup());
    }

    function renderResults(items){
      if (!items.length) {
        results.style.display = "block";
        results.innerHTML = `<div class="item disabled">검색 결과 없음</div>`;
        return;
      }
      results.style.display = "block";
      results.innerHTML = items.map(it=>`
        <div class="item" data-idx="${it.idx}">
          <div><b>${it.company}</b>${it.factory?` · ${it.factory}`:""}</div>
          <div class="sub">${it.addr}</div>
        </div>
      `).join("");
    }

    function doSearch(goFirst=false){
      const kw = normCompact(q.value);
      if (!kw) { results.style.display="none"; results.innerHTML=""; $("resultCount").textContent=""; return; }

      const matched = [];
      for (const it of searchIndex) {
        if (it.key.includes(kw)) matched.push(it);
        if (matched.length >= 80) break;
      }
      renderResults(matched);
      $("resultCount").textContent = `검색 결과: ${matched.length}건`;
      if (goFirst && matched.length) jumpTo(matched[0].idx);
    }

    q.addEventListener("input", ()=>doSearch(false));
    q.addEventListener("keydown", (e)=>{
      if (e.key==="Enter") { e.preventDefault(); doSearch(true); }
    });

    results.addEventListener("click", (e)=>{
      const el = e.target.closest(".item");
      if (!el || el.classList.contains("disabled")) return;
      jumpTo(Number(el.getAttribute("data-idx")));
    });

    /** ===== 우측: 현장주소 → 거리 계산 ===== */
    let siteMarker = null;
    let siteCircle = null;
    let lastGeo = null; // 마지막 지오코딩 결과(정확도 안내용)

    async function geocodeOSM(addr){
      const url = "https://nominatim.openstreetmap.org/search?format=json&limit=1&q=" + encodeURIComponent(addr);
      const r = await fetch(url, { headers: { "Accept": "application/json" } });
      if (!r.ok) throw new Error("Nominatim 응답 오류: " + r.status);
      const j = await r.json();
      if (!j || !j.length) return null;
      return {
        lat: Number(j[0].lat),
        lon: Number(j[0].lon),
        display: j[0].display_name,
        importance: Number(j[0].importance || 0),
        cls: j[0].class || "",
        type: j[0].type || "",
        addresstype: j[0].addresstype || "",
        raw: j[0]
      };
    }

    function buildTopTable(rows, headerHtml=""){
      const top = $("top");
      const sliced = rows.slice(0, 30);

      if (!rows.length) {
        top.innerHTML = `
          <div class="topWrap" style="padding:10px;font-size:12px;color:#777;">
            ${headerHtml || ""}
            <div style="margin-top:6px;">표시할 업체가 없어. <b>생산/믹서 정보가 있는 업체</b>만 거리 리스트에 포함돼.</div>
          </div>`;
        return;
      }

      top.innerHTML = `
        <div class="topWrap">
          ${headerHtml || ""}
          <table class="topTable">
            <colgroup>
              <col style="width:34px"/>
              <col style="width:auto"/>
              <col style="width:60px"/>
              <col style="width:52px"/>
              <col style="width:64px"/>
            </colgroup>
            <thead>
              <tr>
                <th>#</th>
                <th>업체/공장</th>
                <th>생산</th>
                <th>믹서</th>
                <th>거리(km)</th>
              </tr>
            </thead>
            <tbody>
              ${sliced.map((r,i)=>`
                <tr data-idx="${r.idx}" class="${[(r.isHL ? 'hl' : ''), ((r.company||'').includes('아주산업') ? 'ajou' : '')].filter(Boolean).join(' ')}">
                  <td>${i+1}</td>
                  <td><b>${r.company}</b>${r.factory?` · ${r.factory}`:""}<div class="sub">${r.addr||""}</div></td>
                  <td>${r.capacity}</td>
                  <td>${r.mixer}</td>
                  <td>${r.km.toFixed(1)}</td>
                </tr>
              `).join("")}
            </tbody>
          </table>
        </div>
      `;

      top.querySelector("tbody").addEventListener("click", (e)=>{
        const tr = e.target.closest("tr");
        if (!tr) return;
        jumpTo(Number(tr.getAttribute("data-idx")));
      });
    }


    function buildAccuracyNote(geo){
      if (!geo) return "";
      // Nominatim 결과 유형 기반으로 대략적 정확도 안내
      const t = (geo.addresstype || geo.type || "").toLowerCase();
      const cls = (geo.cls || "").toLowerCase();
      const imp = Number(geo.importance || 0);

      let level = "ok";
      if (["country","state","province","region","county","city","town","village","municipality","suburb","borough","district","neighbourhood","administrative"].includes(t) || cls==="boundary") {
        level = "low";
      } else if (["road","street","residential","path","service","tertiary","secondary","primary","trunk","motorway"].includes(t)) {
        level = "mid";
      }

      const msg = (level==="low")
        ? "※ 주소 좌표 정확도가 낮을 수 있어(행정/지역 중심). 마커를 <b>드래그</b>해서 현장 위치를 보정해줘."
        : (level==="mid")
          ? "※ 도로 단위로 변환됐을 수 있어. 필요하면 마커를 <b>드래그</b>해서 위치를 보정해줘."
          : "※ 필요하면 마커를 <b>드래그</b>해서 현장 위치를 보정할 수 있어.";

      return `<div style="padding:8px 10px 2px 10px;font-size:12px;color:#556;">${msg}</div>`;
    }

    function computeRowsFromSite(lat, lon){
      const rows = [];
      markers.forEach((m, idx)=>{
        const r = m.row;
        const company = fmt(r.company_ff);
        const factory = fmt(r.factory);
        const capacity = fmt(r.capacity);
        const mixer = fmt(r.mixer);

        // ✅ 우측 리스트 제외 조건: 생산/믹서 둘 다 숫자여야 함
        const capNum = Number(capacity);
        const mixNum = Number(mixer);
        if (!capacity || !mixer || !isFinite(capNum) || !isFinite(mixNum)) return;

        const km = haversineKm(lat, lon, Number(r.lat), Number(r.lon));
        const isHL = company.replace(/\s+/g,"").includes(HIGHLIGHT);
        rows.push({
          idx, company, factory,
          capacity: String(capNum),
          mixer: String(mixNum),
          km, isHL,
          addr: fmt(r.address)
        });
      });
      rows.sort((a,b)=>a.km-b.km);
      return rows;
    }
    async function calcDistance(){
      const addr = $("site").value.trim();
      if (!addr) return;

      $("top").innerHTML = `<div class="topWrap" style="padding:10px;font-size:12px;color:#555;">주소 좌표를 조회 중…</div>`;

      let geo = null;
      try { geo = await geocodeOSM(addr); }
      catch(err){
        $("top").innerHTML = `<div class="topWrap" style="padding:10px;font-size:12px;color:#b00;">주소 변환 실패: ${err.message}</div>`;
        return;
      }
      if (!geo){
        $("top").innerHTML = `<div class="topWrap" style="padding:10px;font-size:12px;color:#b00;">주소를 찾지 못했어. 더 구체적으로 입력해줘.</div>`;
        return;
      }

      const lat = geo.lat, lon = geo.lon;
      lastGeo = geo;

      // 기존 레이어 제거
      if (siteMarker) map.removeLayer(siteMarker);
      if (siteCircle) map.removeLayer(siteCircle);

      // ✅ 드래그 보정 가능한 현장 마커
      siteMarker = L.marker([lat, lon], { draggable: true, icon: sitePinIcon() })
        .addTo(map)
        .bindPopup(`<b>현장</b><br/>${geo.display}<div style="margin-top:6px;font-size:11px;color:#667;">마커를 드래그해서 위치 보정 가능</div>`)
        .openPopup();

      // 시각적 오차 가이드(반경 50m)
      siteCircle = L.circle([lat, lon], { radius: 50 }).addTo(map);

      map.setView([lat, lon], 12, {animate:true});

      const headerHtml = buildAccuracyNote(geo);
      const rows = computeRowsFromSite(lat, lon);
      buildTopTable(rows, headerHtml);

      // ✅ 드래그로 보정 시 즉시 재계산
      siteMarker.on("dragend", ()=>{
        const p = siteMarker.getLatLng();
        if (siteCircle) siteCircle.setLatLng(p);
        const rows2 = computeRowsFromSite(p.lat, p.lng);
        buildTopTable(rows2, headerHtml);
      });
    }

    $("btnCalc").addEventListener("click", calcDistance);
    $("site").addEventListener("keydown", (e)=>{
      if (e.key==="Enter") { e.preventDefault(); calcDistance(); }
    });

    $("btnClear").addEventListener("click", ()=>{
      if (siteMarker) { map.removeLayer(siteMarker); siteMarker = null; }
      $("site").value = "";
      $("top").innerHTML = "";
    });

  } catch(err){
    showFatal("지도 초기화 실패", err.message || String(err));
  }
})();
</script>

<script>
(function(){
  const mq = window.matchMedia('(max-width: 768px)');
  function setup(){
    const left = document.querySelector('.panel');
    const right = document.querySelector('.panel2');
    const btnL = document.getElementById('btnToggleLeft');
    const btnR = document.getElementById('btnToggleRight');
    if(!left || !right || !btnL || !btnR) return;

    // Default: show map, hide both panels
    left.classList.add('hiddenMobile');
    right.classList.add('hiddenMobile');

    btnL.addEventListener('click', () => {
      const isHidden = left.classList.contains('hiddenMobile');
      left.classList.toggle('hiddenMobile', !isHidden);
      // keep right hidden when opening left
      if(isHidden) right.classList.add('hiddenMobile');
    });
    btnR.addEventListener('click', () => {
      const isHidden = right.classList.contains('hiddenMobile');
      right.classList.toggle('hiddenMobile', !isHidden);
      if(isHidden) left.classList.add('hiddenMobile');
    });
  }

  if(mq.matches){
    // wait for DOM
    if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', setup);
    else setup();
  }
})();
</script>

